DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_FAST_DEV_AUTH=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://*.onrender.com
MTAKA_FRONTEND_URL=https://mtaka-frontend.onrender.com
MTAKA_API_PUBLIC_URL=https://mtaka-backend.onrender.com

# Email delivery
# Local SMTP is optional. For Render, use the Brevo API key below.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
DJANGO_EMAIL_TIMEOUT=20
DJANGO_BREVO_API_KEY=
DJANGO_DEFAULT_FROM_EMAIL=M-Taka No-Reply <no-reply@mtaka.co.ke>
DJANGO_PASSWORD_RESET_TIMEOUT=3600

# M-Pesa Daraja
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_BUSINESS_SHORTCODE=
MPESA_PASSKEY=
# Optional: override the callback URL used for STK push callbacks.
MPESA_CALLBACK_URL=https://mtaka-backend.onrender.com/api/auth/mpesa/callback/
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_TIMEOUT_SECONDS=20
# Preferred: one full URL (Supabase transaction/pooler URL)
# Example:
# DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=

# Alternative explicit Supabase fields (used when DATABASE_URL is empty)
# Use `postgresql` for Supabase, `mysql` for XAMPP MySQL/MariaDB, or `sqlite` for local fallback.
DB_ENGINE=sqlite
SQLITE_DB_PATH=
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
DB_SSLMODE=require
DB_CONN_MAX_AGE=60

# Optional local MySQL fallback (set DB_ENGINE=mysql)
MYSQL_DB_NAME=mtaka
MYSQL_DB_USER=root
MYSQL_DB_PASSWORD=
MYSQL_DB_HOST=127.0.0.1
MYSQL_DB_PORT=3306
