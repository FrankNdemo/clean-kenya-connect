DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_FAST_DEV_AUTH=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Preferred: one full URL (Supabase transaction/pooler URL)
# Example:
# DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=

# Alternative explicit Supabase fields (used when DATABASE_URL is empty)
# Use `postgresql` for Supabase, `mysql` for XAMPP MySQL/MariaDB, or `sqlite` for local fallback.
DB_ENGINE=sqlite
SQLITE_DB_PATH=
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
DB_SSLMODE=require
DB_CONN_MAX_AGE=60

# Optional local MySQL fallback (set DB_ENGINE=mysql)
MYSQL_DB_NAME=mtaka_db
MYSQL_DB_USER=root
MYSQL_DB_PASSWORD=
MYSQL_DB_HOST=127.0.0.1
MYSQL_DB_PORT=3306
